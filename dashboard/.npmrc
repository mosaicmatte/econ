# `npm ci` fails on a clean clone without this, which means nobody could install the
# dashboard from a fresh checkout — including CI.
#
# The conflict is upstream and pre-existing: three-bvh-csg@0.0.18 declares a peer of
# three-mesh-bvh >=0.9.7, while @react-three/drei@9 pins ^0.7.0. npm 7+ treats that as
# fatal. The installed tree resolves three-mesh-bvh to 0.7.8 and the CSG path works
# against it, so the declaration is stricter than the actual requirement.
#
# This flag records the decision instead of leaving it in whoever's shell history. The
# real fix is drei v10, which drops the pin — that is a major upgrade of the 3D layer and
# wants its own change with the scene verified afterwards, not a drive-by.
legacy-peer-deps=true
